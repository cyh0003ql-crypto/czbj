.tab-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  height: 112rpx;
  background: #faf8f5;
  display: flex;
  align-items: center;
  padding-bottom: env(safe-area-inset-bottom);
  z-index: 999;
}

.tab-bar-border {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 1rpx;
  background: #ede6dc;
}

.tab-bar-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 4rpx;
  padding-top: 10rpx;
  position: relative;
}

.tab-center {
  position: relative;
  top: -24rpx;
}

.center-btn {
  width: 96rpx;
  height: 96rpx;
  background: #3d2a1e;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 20rpx rgba(61, 42, 30, 0.35);
}

.center-plus {
  font-size: 48rpx;
  color: #fff;
  font-weight: 300;
  line-height: 1;
  margin-top: -4rpx;
}

.icon-wrap {
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
}

.tab-icon {
  font-size: 40rpx;
  color: #999;
  display: block;
  line-height: 1;
  transition: color 0.2s;
}

.tab-icon-selected {
  color: #3d2a1e;
}

.tab-text {
  font-size: 20rpx;
  color: #999;
  transition: color 0.2s;
}

.tab-text-selected {
  color: #3d2a1e;
  font-weight: 600;
}

.cart-badge {
  position: absolute;
  top: -8rpx;
  right: -16rpx;
  background: #e8624a;
  border-radius: 20rpx;
  min-width: 32rpx;
  height: 32rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 6rpx;
}

.cart-badge text {
  font-size: 18rpx;
  color: #fff;
  font-weight: 700;
}

.selected .tab-text {
  color: #3d2a1e;
  font-weight: 600;
}
