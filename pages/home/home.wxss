.home-page {
  background: #f5f0eb;
  min-height: 100vh;
}

/* 导航栏 */
.nav-bar {
  background: #faf8f5;
  padding-bottom: 16rpx;
}

.nav-content {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 30rpx 0;
}

.nav-brand {
  font-size: 36rpx;
  font-weight: 700;
  color: #2c2c2c;
  display: block;
}

.nav-slogan {
  font-size: 20rpx;
  color: #999;
  display: block;
  margin-top: 4rpx;
}

.nav-icons {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.nav-icon, .scan-icon {
  font-size: 36rpx;
  color: #6b4f3a;
}

/* 搜索栏 */
.search-bar {
  display: flex;
  align-items: center;
  background: #f5f0eb;
  border-radius: 40rpx;
  margin: 16rpx 24rpx;
  padding: 18rpx 24rpx;
  gap: 12rpx;
}

.search-icon {
  font-size: 28rpx;
  color: #bbb;
}

.search-placeholder {
  font-size: 26rpx;
  color: #bbb;
}

/* 轮播图 */
.banner-wrap {
  margin: 0 24rpx 24rpx;
}

.banner-swiper {
  height: 320rpx;
  border-radius: 20rpx;
  overflow: hidden;
}

.banner-item {
  display: flex;
  align-items: center;
  height: 100%;
  background: #ede0d0;
  border-radius: 20rpx;
  overflow: hidden;
  position: relative;
  padding: 36rpx;
}

.banner-text {
  flex: 1;
  z-index: 2;
}

.banner-title {
  font-size: 42rpx;
  font-weight: 800;
  color: #2c2c2c;
  display: block;
  line-height: 1.3;
}

.banner-desc {
  font-size: 24rpx;
  color: #8b6f5e;
  display: block;
  margin: 12rpx 0 20rpx;
}

.banner-btn {
  display: inline-flex;
  align-items: center;
  background: #3d2a1e;
  color: #fff;
  font-size: 24rpx;
  padding: 14rpx 28rpx;
  border-radius: 32rpx;
  font-weight: 500;
}

.banner-img {
  position: absolute;
  right: 0;
  top: 0;
  width: 52%;
  height: 100%;
}

/* 功能入口 */
.feature-section {
  margin: 0 24rpx 24rpx;
  padding: 30rpx 20rpx;
}

.feature-grid {
  display: flex;
  justify-content: space-around;
}

.feature-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex: 1;
}

.feature-icon-wrap {
  width: 88rpx;
  height: 88rpx;
  background: #f0e8de;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 12rpx;
}

.feature-icon {
  font-size: 36rpx;
}

.feature-name {
  font-size: 24rpx;
  font-weight: 600;
  color: #2c2c2c;
  display: block;
}

.feature-desc {
  font-size: 18rpx;
  color: #999;
  display: block;
  margin-top: 4rpx;
  text-align: center;
}

/* 商品网格 */
.product-grid {
  display: flex;
  flex-wrap: wrap;
  padding: 0 24rpx;
  gap: 20rpx;
}

.product-card {
  width: calc(50% - 10rpx);
  overflow: hidden;
}

.product-img-wrap {
  position: relative;
  width: 100%;
  height: 320rpx;
}

.product-img {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.wishlist-btn {
  position: absolute;
  top: 16rpx;
  right: 16rpx;
  width: 56rpx;
  height: 56rpx;
  background: rgba(255,255,255,0.85);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.wishlist-icon {
  font-size: 32rpx;
  color: #bbb;
}

.wishlist-icon.wished {
  color: #e8624a;
}

.product-info {
  padding: 16rpx;
}

.product-name {
  font-size: 26rpx;
  font-weight: 600;
  color: #2c2c2c;
  display: block;
  margin-bottom: 10rpx;
}

.product-tags {
  display: flex;
  flex-wrap: wrap;
  margin-bottom: 12rpx;
  gap: 6rpx;
}

.product-price {
  display: flex;
  align-items: baseline;
  color: #3d2a1e;
}

.price-unit {
  font-size: 22rpx;
  font-weight: 500;
}

.price-num {
  font-size: 36rpx;
  font-weight: 700;
  margin: 0 2rpx;
}

.price-suffix {
  font-size: 20rpx;
  color: #999;
  font-weight: 400;
}
