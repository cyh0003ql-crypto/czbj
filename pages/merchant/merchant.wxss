.merchant-page {
  background: #f5f0eb;
  min-height: 100vh;
}

/* 导航 */
.merchant-nav {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 30rpx;
  background: #faf8f5;
}

.nav-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #2c2c2c;
}

.nav-icons {
  display: flex;
  gap: 20rpx;
  font-size: 36rpx;
}

.nav-btn {
  color: #6b4f3a;
}

/* 商家信息 */
.merchant-info {
  margin: 16rpx 24rpx;
  padding: 24rpx;
}

.merchant-profile {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 30rpx;
}

.merchant-avatar {
  width: 96rpx;
  height: 96rpx;
  border-radius: 16rpx;
  flex-shrink: 0;
}

.merchant-detail {
  flex: 1;
}

.merchant-name-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 6rpx;
}

.merchant-name {
  font-size: 30rpx;
  font-weight: 700;
  color: #2c2c2c;
}

.verified-badge {
  background: #f0e8de;
  color: #8b6f5e;
  font-size: 18rpx;
  padding: 4rpx 12rpx;
  border-radius: 6rpx;
}

.merchant-slogan {
  display: block;
  font-size: 22rpx;
  color: #999;
}

.shop-setting-btn {
  font-size: 22rpx;
  color: #6b4f3a;
  background: #f0e8de;
  padding: 10rpx 20rpx;
  border-radius: 20rpx;
  white-space: nowrap;
}

/* 数据统计 */
.stat-grid {
  display: flex;
  justify-content: space-around;
  padding: 20rpx 0 10rpx;
  border-top: 1rpx solid #f0ebe4;
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}

.stat-num {
  font-size: 52rpx;
  font-weight: 800;
  color: #2c2c2c;
}

.stat-num.warning {
  color: #e8624a;
}

.stat-label {
  font-size: 22rpx;
  color: #999;
}

/* 订单流程 */
.order-flow {
  margin: 16rpx 24rpx;
  padding: 24rpx;
}

.section-top {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.section-label {
  font-size: 28rpx;
  font-weight: 700;
  color: #2c2c2c;
}

.view-all {
  font-size: 22rpx;
  color: #6b4f3a;
}

.flow-scroll {
  width: 100%;
  white-space: nowrap;
}

.flow-steps {
  display: flex;
  align-items: center;
  gap: 0;
}

.flow-step {
  display: inline-flex;
  flex-direction: column;
  align-items: center;
  gap: 10rpx;
  flex-shrink: 0;
  width: 140rpx;
  position: relative;
}

.flow-icon-wrap {
  position: relative;
  width: 80rpx;
  height: 80rpx;
  background: #f0e8de;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.flow-icon {
  font-size: 36rpx;
}

.flow-badge {
  position: absolute;
  top: -6rpx;
  right: -6rpx;
  background: #e8624a;
  color: #fff;
  font-size: 18rpx;
  min-width: 32rpx;
  height: 32rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 6rpx;
}

.flow-label {
  font-size: 22rpx;
  color: #666;
  display: block;
  text-align: center;
}

.flow-arrow {
  position: absolute;
  right: -20rpx;
  top: 28rpx;
  font-size: 20rpx;
  color: #ddd;
  letter-spacing: -4rpx;
}

/* 功能区 */
.function-section {
  margin: 16rpx 24rpx;
  padding: 24rpx;
}

.func-title {
  display: block;
  font-size: 28rpx;
  font-weight: 700;
  color: #2c2c2c;
  margin-bottom: 24rpx;
}

.func-grid {
  display: flex;
  justify-content: space-around;
}

.func-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
  flex: 1;
}

.func-icon-wrap {
  width: 88rpx;
  height: 88rpx;
  background: #f0e8de;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
}

.func-label {
  font-size: 24rpx;
  color: #666;
  text-align: center;
}

/* 数据看板 */
.dashboard-section {
  margin: 16rpx 24rpx;
  padding: 24rpx;
}

.dashboard-grid {
  display: flex;
  justify-content: space-around;
  flex-wrap: wrap;
  gap: 20rpx;
}

.dash-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  width: 40%;
  background: #f5f0eb;
  border-radius: 16rpx;
  padding: 24rpx;
  gap: 8rpx;
}

.dash-num {
  font-size: 40rpx;
  font-weight: 800;
  color: #3d2a1e;
}

.dash-label {
  font-size: 22rpx;
  color: #999;
}

/* 接口提示 */
.api-tips {
  margin: 16rpx 24rpx;
  padding: 24rpx;
  background: #f8f4ef;
}

.tips-title {
  display: block;
  font-size: 26rpx;
  font-weight: 700;
  color: #3d2a1e;
  margin-bottom: 16rpx;
}

.tips-item {
  display: block;
  font-size: 22rpx;
  color: #888;
  font-family: monospace;
  margin-bottom: 8rpx;
  line-height: 1.6;
}
