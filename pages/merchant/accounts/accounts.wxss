.accounts-page { background: #f5f0eb; min-height: 100vh; padding: 20rpx 24rpx 60rpx; }

.card { background: #faf8f5; border-radius: 16rpx; box-shadow: 0 2rpx 16rpx rgba(107,79,58,0.06); }

.owner-card { display: flex; align-items: center; gap: 20rpx; padding: 28rpx 24rpx; margin-bottom: 28rpx; }
.owner-icon { font-size: 48rpx; flex-shrink: 0; }
.owner-info { flex: 1; }
.owner-title { display: block; font-size: 30rpx; font-weight: 700; color: #2c2c2c; margin-bottom: 4rpx; }
.owner-username { display: block; font-size: 24rpx; color: #6b4f3a; margin-bottom: 4rpx; }
.owner-desc { display: block; font-size: 22rpx; color: #999; }
.owner-badge { background: #3d2a1e; color: #fff; font-size: 20rpx; padding: 6rpx 16rpx; border-radius: 20rpx; white-space: nowrap; }

.section-title-row { display: flex; justify-content: space-between; align-items: center; margin-bottom: 16rpx; }
.section-title-txt { font-size: 28rpx; font-weight: 700; color: #2c2c2c; }
.add-sub-btn { background: #3d2a1e; color: #fff; font-size: 24rpx; padding: 14rpx 28rpx; border-radius: 32rpx; font-weight: 600; }

.sub-list { display: flex; flex-direction: column; gap: 16rpx; }

.sub-card { padding: 24rpx; overflow: hidden; }

.sub-header { display: flex; align-items: center; gap: 16rpx; margin-bottom: 20rpx; }
.sub-avatar { width: 72rpx; height: 72rpx; border-radius: 50%; background: linear-gradient(135deg, #8b6f5e, #3d2a1e); color: #fff; font-size: 30rpx; display: flex; align-items: center; justify-content: center; font-weight: 700; flex-shrink: 0; }
.sub-info { flex: 1; }
.sub-name { display: block; font-size: 28rpx; font-weight: 700; color: #2c2c2c; }
.sub-username { display: block; font-size: 22rpx; color: #999; }

.sub-perms { display: flex; flex-wrap: wrap; gap: 10rpx; margin-bottom: 20rpx; }
.perm-tag { font-size: 22rpx; padding: 6rpx 16rpx; border-radius: 8rpx; }
.perm-on { background: #f0e8de; color: #3d2a1e; }
.perm-off { background: #f5f5f5; color: #bbb; text-decoration: line-through; }

.sub-actions { display: flex; justify-content: flex-end; gap: 16rpx; border-top: 1rpx solid #f5f0eb; padding-top: 16rpx; }
.sub-btn { font-size: 24rpx; color: #6b4f3a; padding: 10rpx 20rpx; border: 1rpx solid #e0d4c8; border-radius: 8rpx; }
.sub-btn.danger { color: #e8624a; border-color: #f5c5bb; }

.empty-state { display: flex; flex-direction: column; align-items: center; padding: 80rpx 0; gap: 12rpx; color: #bbb; font-size: 28rpx; }
.empty-icon { font-size: 80rpx; }
.empty-sub { font-size: 24rpx; color: #bbb; }

/* 表单弹窗 */
.form-mask { position: fixed; inset: 0; background: rgba(0,0,0,0.4); z-index: 100; }
.sub-form { position: fixed; bottom: -100%; left: 0; right: 0; border-radius: 32rpx 32rpx 0 0; z-index: 200; transition: bottom 0.3s ease; max-height: 90vh; overflow-y: auto; }
.sub-form.form-show { bottom: 0; }

.form-header { display: flex; justify-content: space-between; align-items: center; padding: 30rpx; border-bottom: 1rpx solid #f0ebe4; position: sticky; top: 0; background: #faf8f5; z-index: 1; }
.form-title { font-size: 32rpx; font-weight: 700; color: #2c2c2c; }
.form-close { font-size: 36rpx; color: #bbb; }

.form-item { display: flex; align-items: center; padding: 22rpx 30rpx; border-bottom: 1rpx solid #f5f0eb; gap: 16rpx; }
.fl { width: 140rpx; font-size: 28rpx; color: #666; flex-shrink: 0; }
.fi { flex: 1; font-size: 28rpx; color: #2c2c2c; }

.perm-section-title { display: block; font-size: 26rpx; font-weight: 700; color: #2c2c2c; padding: 24rpx 30rpx 12rpx; border-left: 6rpx solid #3d2a1e; margin-left: 30rpx; }
.perm-toggles { padding: 0 30rpx; }
.perm-toggle-row { display: flex; align-items: center; justify-content: space-between; padding: 20rpx 0; border-bottom: 1rpx solid #f5f0eb; }
.perm-toggle-info { display: flex; align-items: center; gap: 16rpx; }
.perm-toggle-icon { font-size: 36rpx; }
.perm-toggle-label { display: block; font-size: 28rpx; color: #2c2c2c; font-weight: 600; }
.perm-toggle-desc { display: block; font-size: 22rpx; color: #999; }

.form-submit { margin: 24rpx 30rpx; background: #3d2a1e; color: #fff; text-align: center; border-radius: 48rpx; line-height: 90rpx; font-size: 30rpx; font-weight: 600; }
