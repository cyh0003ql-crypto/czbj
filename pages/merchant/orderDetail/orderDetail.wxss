.order-detail-page { background: #f5f0eb; min-height: 100vh; padding-bottom: 180rpx; }

.status-banner { display: flex; align-items: center; gap: 20rpx; padding: 40rpx 30rpx; }
.status-icon-big { font-size: 64rpx; }
.status-text-big { display: block; font-size: 36rpx; font-weight: 700; color: #fff; }
.status-sub { display: block; font-size: 24rpx; color: rgba(255,255,255,0.8); margin-top: 6rpx; }

.card { background: #faf8f5; border-radius: 16rpx; box-shadow: 0 2rpx 16rpx rgba(107,79,58,0.06); margin: 16rpx 24rpx; padding: 24rpx; }

/* 进度 */
.progress-section { padding: 30rpx; }
.progress-step { display: flex; align-items: flex-start; gap: 20rpx; position: relative; padding-bottom: 24rpx; }
.progress-step.done .step-name { color: #3d2a1e; font-weight: 600; }
.step-dot { width: 20rpx; height: 20rpx; border-radius: 50%; background: #e8e0d8; flex-shrink: 0; margin-top: 6rpx; }
.dot-done { background: #3d2a1e; }
.step-info { flex: 1; }
.step-name { display: block; font-size: 26rpx; color: #999; }
.step-time { display: block; font-size: 22rpx; color: #bbb; margin-top: 4rpx; }
.step-line { position: absolute; left: 9rpx; top: 26rpx; bottom: 0; width: 2rpx; background: #e8e0d8; }

/* 地址 */
.addr-section { display: flex; align-items: flex-start; gap: 20rpx; }
.addr-icon { font-size: 36rpx; margin-top: 4rpx; }
.addr-name-phone { display: flex; gap: 16rpx; margin-bottom: 8rpx; }
.an { font-size: 30rpx; font-weight: 700; color: #2c2c2c; }
.ap { font-size: 26rpx; color: #666; }
.addr-full { font-size: 26rpx; color: #666; display: block; }

/* 商品 */
.goods-title { display: block; font-size: 28rpx; font-weight: 700; color: #2c2c2c; margin-bottom: 20rpx; }
.good-row { display: flex; gap: 16rpx; margin-bottom: 20rpx; }
.g-img { width: 140rpx; height: 140rpx; border-radius: 10rpx; flex-shrink: 0; }
.g-info { flex: 1; }
.g-name { display: block; font-size: 26rpx; font-weight: 600; color: #2c2c2c; margin-bottom: 6rpx; }
.g-spec { display: block; font-size: 22rpx; color: #999; margin-bottom: 8rpx; }
.g-price-row { display: flex; justify-content: space-between; }
.g-price { font-size: 28rpx; font-weight: 700; color: #3d2a1e; }
.g-qty { font-size: 24rpx; color: #999; }

.price-summary { border-top: 1rpx solid #f0ebe4; padding-top: 20rpx; display: flex; flex-direction: column; gap: 12rpx; }
.ps-row { display: flex; justify-content: space-between; font-size: 26rpx; color: #666; }
.ps-row.discount text { color: #52b788; }
.total-row { margin-top: 8rpx; }
.total-l { font-size: 28rpx; font-weight: 700; color: #2c2c2c; }
.total-r { font-size: 36rpx; font-weight: 800; color: #3d2a1e; }

/* 定制需求 */
.custom-section { }
.cs-title { display: block; font-size: 28rpx; font-weight: 700; color: #2c2c2c; margin-bottom: 16rpx; }
.cs-desc { display: block; font-size: 26rpx; color: #666; line-height: 1.6; margin-bottom: 16rpx; }
.cs-images { display: flex; flex-wrap: wrap; gap: 12rpx; }
.cs-img { width: 160rpx; height: 160rpx; border-radius: 8rpx; }

/* 订单信息 */
.info-row { display: flex; justify-content: space-between; padding: 14rpx 0; border-bottom: 1rpx solid #f5f0eb; }
.il { font-size: 26rpx; color: #999; }
.ir { font-size: 26rpx; color: #2c2c2c; }
.copy-text { color: #6b4f3a; }

/* 操作 */
.action-section { position: fixed; bottom: 0; left: 0; right: 0; background: #faf8f5; border-top: 1rpx solid #ede6dc; padding: 16rpx 24rpx; padding-bottom: calc(16rpx + env(safe-area-inset-bottom)); }
.action-row { display: flex; gap: 16rpx; margin-bottom: 12rpx; }
.action-row:last-child { margin-bottom: 0; }
.contact-row { justify-content: flex-end; }
.action-input-wrap { flex: 1; background: #f0e8de; border-radius: 40rpx; padding: 0 24rpx; }
.quote-input { height: 80rpx; font-size: 26rpx; }
.action-btn { padding: 20rpx 36rpx; border-radius: 40rpx; font-size: 26rpx; font-weight: 600; white-space: nowrap; }
.action-btn.primary { background: #3d2a1e; color: #fff; }
.action-btn.secondary { background: #f0e8de; color: #3d2a1e; border: 1rpx solid #d4c4b0; }
.action-btn.full { flex: 1; text-align: center; }
