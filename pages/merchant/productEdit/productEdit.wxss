.product-edit-page { background: #f5f0eb; min-height: 100vh; padding: 20rpx 24rpx 180rpx; }

.form-section { margin-bottom: 20rpx; padding: 24rpx; }
.section-label { display: block; font-size: 28rpx; font-weight: 700; color: #2c2c2c; margin-bottom: 20rpx; border-left: 6rpx solid #3d2a1e; padding-left: 16rpx; }

.form-item { display: flex; align-items: center; padding: 22rpx 0; border-bottom: 1rpx solid #f5f0eb; gap: 16rpx; }
.toggle-item { justify-content: space-between; }
.fl { width: 160rpx; font-size: 28rpx; color: #666; flex-shrink: 0; }
.fi { flex: 1; font-size: 28rpx; color: #2c2c2c; }
.picker-val { flex: 1; font-size: 28rpx; color: #2c2c2c; display: flex; justify-content: space-between; }
.arr { color: #bbb; }

.tag-input-row { display: flex; gap: 16rpx; margin-bottom: 16rpx; }
.tag-input { flex: 1; background: #f5f0eb; border-radius: 8rpx; padding: 14rpx 20rpx; font-size: 26rpx; }
.add-tag-btn { background: #3d2a1e; color: #fff; font-size: 26rpx; padding: 14rpx 28rpx; border-radius: 8rpx; white-space: nowrap; }
.tag-list { display: flex; flex-wrap: wrap; gap: 12rpx; }
.tag-item { background: #f0e8de; color: #3d2a1e; font-size: 24rpx; padding: 8rpx 16rpx; border-radius: 8rpx; display: flex; align-items: center; gap: 8rpx; }
.tag-del { color: #bbb; font-size: 20rpx; }

.img-upload-grid { display: flex; flex-wrap: wrap; gap: 16rpx; }
.upload-thumb { width: 160rpx; height: 160rpx; position: relative; border-radius: 12rpx; overflow: hidden; }
.thumb-img { width: 100%; height: 100%; }
.del-img { position: absolute; top: -4rpx; right: -4rpx; background: rgba(0,0,0,0.5); color: #fff; width: 36rpx; height: 36rpx; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 18rpx; }
.upload-add { width: 160rpx; height: 160rpx; background: #f0e8de; border-radius: 12rpx; border: 2rpx dashed #c9a882; display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 8rpx; }
.plus { font-size: 48rpx; color: #c9a882; }
.plus-label { font-size: 22rpx; color: #bbb; }

.spec-row { display: flex; align-items: center; gap: 12rpx; margin-bottom: 16rpx; }
.spec-label-input { width: 180rpx; background: #f5f0eb; border-radius: 8rpx; padding: 14rpx 16rpx; font-size: 26rpx; }
.spec-value-input { flex: 1; background: #f5f0eb; border-radius: 8rpx; padding: 14rpx 16rpx; font-size: 26rpx; }
.del-spec { color: #bbb; font-size: 32rpx; padding: 8rpx; }
.add-spec-btn { color: #6b4f3a; font-size: 26rpx; padding: 16rpx 0; border: 1rpx dashed #c9a882; text-align: center; border-radius: 8rpx; margin-top: 8rpx; }

.desc-input { width: 100%; min-height: 200rpx; background: #f5f0eb; border-radius: 12rpx; padding: 20rpx; font-size: 26rpx; color: #2c2c2c; }
.desc-count { display: block; text-align: right; font-size: 22rpx; color: #bbb; margin-top: 8rpx; }

.bottom-actions { position: fixed; bottom: 0; left: 0; right: 0; display: flex; gap: 20rpx; padding: 20rpx 30rpx; padding-bottom: calc(20rpx + env(safe-area-inset-bottom)); background: #faf8f5; border-top: 1rpx solid #ede6dc; }
.save-btn { flex: 1; text-align: center; line-height: 88rpx; background: #f0e8de; color: #3d2a1e; border-radius: 44rpx; font-size: 28rpx; font-weight: 600; }
.publish-btn { flex: 1.5; text-align: center; line-height: 88rpx; background: #3d2a1e; color: #fff; border-radius: 44rpx; font-size: 28rpx; font-weight: 600; }
