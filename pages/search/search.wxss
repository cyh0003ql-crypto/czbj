.search-page { background: #f5f0eb; min-height: 100vh; }

.search-header {
  display: flex;
  align-items: center;
  padding: 16rpx 24rpx;
  background: #faf8f5;
  gap: 16rpx;
  border-bottom: 1rpx solid #ede6dc;
}

.search-input-wrap {
  flex: 1;
  display: flex;
  align-items: center;
  background: #f0ebe4;
  border-radius: 40rpx;
  padding: 16rpx 24rpx;
  gap: 12rpx;
}

.search-icon-txt { font-size: 28rpx; flex-shrink: 0; }

.search-input {
  flex: 1;
  font-size: 28rpx;
  color: #2c2c2c;
}

.clear-btn {
  font-size: 28rpx;
  color: #bbb;
  padding: 4rpx;
}

.cancel-btn {
  font-size: 28rpx;
  color: #6b4f3a;
  white-space: nowrap;
}

/* 热门 */
.hot-section { padding: 30rpx 24rpx; }

.hot-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.hot-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #2c2c2c;
}

.clear-history { font-size: 24rpx; color: #999; }

.hot-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-bottom: 40rpx;
}

.hot-tag {
  background: #faf8f5;
  border: 1rpx solid #e8e0d8;
  border-radius: 32rpx;
  padding: 12rpx 28rpx;
  font-size: 26rpx;
  color: #3d2a1e;
}

.history-section { margin-top: 30rpx; }

.history-list { margin-top: 16rpx; }

.history-item {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f0ebe4;
}

.history-icon { font-size: 28rpx; color: #bbb; }
.history-text { font-size: 28rpx; color: #666; }

/* 结果 */
.loading-wrap {
  text-align: center;
  padding: 80rpx;
  color: #bbb;
  font-size: 28rpx;
}

.results-section { padding: 0 24rpx; }

.result-count {
  display: block;
  font-size: 24rpx;
  color: #999;
  padding: 20rpx 0 16rpx;
}

.result-list { display: flex; flex-direction: column; gap: 16rpx; }

.result-item {
  display: flex;
  align-items: center;
  padding: 16rpx;
  gap: 16rpx;
}

.result-img {
  width: 160rpx;
  height: 160rpx;
  border-radius: 12rpx;
  flex-shrink: 0;
}

.result-info { flex: 1; }

.result-name {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: #2c2c2c;
  margin-bottom: 8rpx;
}

.result-tags { display: flex; gap: 6rpx; margin-bottom: 10rpx; }

.result-price { display: flex; align-items: baseline; color: #3d2a1e; }
.price-unit { font-size: 20rpx; }
.price-main { font-size: 32rpx; font-weight: 700; }
.price-start { font-size: 18rpx; color: #999; }

.result-cart {
  width: 60rpx;
  height: 60rpx;
  background: #3d2a1e;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
  flex-shrink: 0;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 100rpx 0;
  gap: 16rpx;
  color: #bbb;
  font-size: 28rpx;
}
.empty-icon { font-size: 80rpx; }
.empty-sub { font-size: 24rpx; color: #bbb; }
