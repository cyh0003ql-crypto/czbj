<view class="search-page">
  <!-- 搜索栏 -->
  <view class="search-header">
    <view class="search-input-wrap">
      <text class="search-icon-txt">🔍</text>
      <input
        class="search-input"
        placeholder="搜索商品或服务"
        placeholder-style="color:#bbb;"
        focus="{{true}}"
        value="{{keyword}}"
        bindinput="onInput"
        bindconfirm="onSearch"
        confirm-type="search"
      />
      <view class="clear-btn" wx:if="{{keyword}}" bindtap="clearKeyword">✕</view>
    </view>
    <view class="cancel-btn" bindtap="goBack">取消</view>
  </view>

  <!-- 热门搜索（无关键词时） -->
  <view wx:if="{{!keyword && !results.length}}" class="hot-section">
    <view class="hot-header">
      <text class="hot-title">热门搜索</text>
      <view class="clear-history" bindtap="clearHistory" wx:if="{{searchHistory.length}}">清除历史</view>
    </view>
    <view class="hot-tags">
      <view class="hot-tag" wx:for="{{hotKeywords}}" wx:key="*this" bindtap="onHotTap" data-kw="{{item}}">
        {{item}}
      </view>
    </view>

    <view wx:if="{{searchHistory.length}}" class="history-section">
      <text class="hot-title">搜索历史</text>
      <view class="history-list">
        <view class="history-item" wx:for="{{searchHistory}}" wx:key="*this" bindtap="onHotTap" data-kw="{{item}}">
          <text class="history-icon">🕐</text>
          <text class="history-text">{{item}}</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 搜索结果 -->
  <view wx:if="{{searching}}" class="loading-wrap">
    <text>搜索中...</text>
  </view>

  <view wx:elif="{{results.length}}" class="results-section">
    <text class="result-count">共找到 {{results.length}} 件商品</text>
    <view class="result-list">
      <view class="result-item card" wx:for="{{results}}" wx:key="id" bindtap="goProductDetail" data-id="{{item.id}}">
        <image class="result-img" src="{{item.image}}" mode="aspectFill" lazy-load="{{true}}"></image>
        <view class="result-info">
          <text class="result-name">{{item.name}}</text>
          <view class="result-tags">
            <text class="tag" wx:for="{{item.tags}}" wx:key="*this" wx:for-item="tag">{{tag}}</text>
          </view>
          <view class="result-price">
            <text class="price-unit">¥</text>
            <text class="price-main">{{item.price}}</text>
            <text class="price-start"> 起</text>
          </view>
        </view>
        <view class="result-cart" catchtap="addToCart" data-id="{{item.id}}">🛒</view>
      </view>
    </view>
  </view>

  <view wx:elif="{{searched && !results.length}}" class="empty-state">
    <text class="empty-icon">🔍</text>
    <text>没有找到"{{keyword}}"相关商品</text>
    <text class="empty-sub">试试其他关键词</text>
  </view>
</view>
