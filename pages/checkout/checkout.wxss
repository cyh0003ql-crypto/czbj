.checkout-page { background: #f5f0eb; min-height: 100vh; }

.section-card {
  background: #faf8f5;
  border-radius: 16rpx;
  box-shadow: 0 2rpx 12rpx rgba(107,79,58,0.06);
  margin: 16rpx 24rpx;
  overflow: hidden;
}

/* 收货地址 */
.addr-card { padding: 24rpx; }
.addr-content { display: flex; align-items: flex-start; gap: 16rpx; }
.addr-icon-wrap { font-size: 32rpx; padding-top: 4rpx; }
.addr-detail { flex: 1; }
.addr-name-row { display: flex; align-items: center; gap: 12rpx; margin-bottom: 8rpx; }
.addr-name { font-size: 30rpx; font-weight: 700; color: #2c2c2c; }
.addr-phone { font-size: 26rpx; color: #666; }
.default-tag { background: #f0e8de; color: #8b6f5e; font-size: 18rpx; padding: 4rpx 10rpx; border-radius: 4rpx; }
.addr-full { font-size: 26rpx; color: #666; line-height: 1.5; display: block; }
.addr-arrow { font-size: 36rpx; color: #bbb; flex-shrink: 0; align-self: center; }
.no-addr { display: flex; align-items: center; gap: 16rpx; color: #999; font-size: 28rpx; }
.no-addr-icon { font-size: 32rpx; }
.no-addr-text { flex: 1; }

/* 店铺 */
.shop-card { }
.shop-header { display: flex; align-items: center; gap: 12rpx; padding: 20rpx 24rpx; border-bottom: 1rpx solid #f0ebe4; }
.shop-icon { font-size: 28rpx; }
.shop-name { font-size: 26rpx; font-weight: 600; color: #2c2c2c; }

.order-items { padding: 16rpx 24rpx; border-bottom: 1rpx solid #f0ebe4; }
.order-item { display: flex; gap: 16rpx; padding: 12rpx 0; }
.oi-img { width: 120rpx; height: 120rpx; border-radius: 10rpx; flex-shrink: 0; }
.oi-info { flex: 1; }
.oi-name { display: block; font-size: 26rpx; font-weight: 600; color: #2c2c2c; margin-bottom: 6rpx; }
.oi-spec { display: block; font-size: 22rpx; color: #999; margin-bottom: 8rpx; }
.oi-price-row { display: flex; justify-content: space-between; }
.oi-price { font-size: 28rpx; font-weight: 700; color: #3d2a1e; }
.oi-qty { font-size: 22rpx; color: #999; }

.remark-row { display: flex; align-items: center; padding: 20rpx 24rpx; gap: 16rpx; }
.remark-label { font-size: 26rpx; color: #999; white-space: nowrap; }
.remark-input { flex: 1; font-size: 26rpx; color: #2c2c2c; }

/* 行 */
.coupon-row { display: flex; align-items: center; justify-content: space-between; padding: 28rpx 24rpx; }
.info-row { display: flex; align-items: center; justify-content: space-between; padding: 22rpx 24rpx; }
.info-row + .info-row { border-top: 1rpx solid #f5f0eb; }
.row-left { display: flex; align-items: center; gap: 12rpx; }
.row-icon { font-size: 28rpx; }
.row-label { font-size: 28rpx; color: #2c2c2c; }
.row-right { display: flex; align-items: center; gap: 8rpx; }
.row-value { font-size: 26rpx; color: #666; }
.row-arrow { font-size: 32rpx; color: #bbb; }
.coupon-hint { font-size: 26rpx; color: #999; }
.coupon-hint.has-coupon { color: #e8624a; font-weight: 600; }

/* 支付方式 */
.pay-method-row { display: flex; align-items: center; justify-content: space-between; padding: 22rpx 24rpx; }
.pay-options { display: flex; gap: 16rpx; }
.pay-opt { display: flex; align-items: center; gap: 8rpx; padding: 12rpx 24rpx; border: 2rpx solid #e8e0d8; border-radius: 32rpx; font-size: 24rpx; color: #666; }
.pay-opt.selected { border-color: #3d2a1e; background: #f5f0eb; color: #3d2a1e; font-weight: 600; }
.pay-opt-icon { color: #4CAF50; }

/* 价格明细 */
.price-detail-card { padding: 24rpx; }
.pd-title { display: block; font-size: 28rpx; font-weight: 700; color: #2c2c2c; margin-bottom: 20rpx; }
.pd-row { display: flex; justify-content: space-between; align-items: center; padding: 12rpx 0; }
.pd-label { font-size: 26rpx; color: #666; }
.pd-val { font-size: 26rpx; color: #2c2c2c; }
.discount-row .pd-val { color: #e8624a; }
.discount-val { font-weight: 600; }
.pd-divider { height: 1rpx; background: #f0ebe4; margin: 12rpx 0; }
.total-row { padding: 16rpx 0 0; }
.pd-label-total { font-size: 30rpx; font-weight: 700; color: #2c2c2c; }
.pd-total-price { display: flex; align-items: baseline; color: #3d2a1e; }
.pd-unit { font-size: 22rpx; }
.pd-total-num { font-size: 48rpx; font-weight: 800; }

/* 提交栏 */
.submit-bar { position: fixed; bottom: 0; left: 0; right: 0; background: #faf8f5; border-top: 1rpx solid #ede6dc; display: flex; align-items: center; justify-content: space-between; padding: 16rpx 24rpx; padding-bottom: calc(16rpx + env(safe-area-inset-bottom)); }
.submit-total { display: flex; align-items: baseline; gap: 4rpx; }
.st-label { font-size: 24rpx; color: #666; }
.st-unit { font-size: 22rpx; color: #3d2a1e; font-weight: 600; }
.st-price { font-size: 44rpx; font-weight: 800; color: #3d2a1e; }
.submit-btn { background: #3d2a1e; color: #fff; border-radius: 48rpx; padding: 22rpx 60rpx; font-size: 30rpx; font-weight: 600; }
.submit-btn.submitting { background: #8b6f5e; }

/* 优惠券弹窗 */
.coupon-mask { position: fixed; inset: 0; background: rgba(0,0,0,0); z-index: 200; transition: background 0.3s; pointer-events: none; }
.coupon-mask.show { background: rgba(0,0,0,0.45); pointer-events: auto; }
.coupon-panel { position: fixed; bottom: -100%; left: 0; right: 0; background: #faf8f5; border-radius: 32rpx 32rpx 0 0; z-index: 201; transition: bottom 0.35s cubic-bezier(0.32,0.72,0,1); max-height: 75vh; display: flex; flex-direction: column; }
.coupon-panel.panel-show { bottom: 0; }
.cp-header { display: flex; justify-content: space-between; align-items: center; padding: 30rpx; border-bottom: 1rpx solid #f0ebe4; flex-shrink: 0; }
.cp-title { font-size: 32rpx; font-weight: 700; color: #2c2c2c; }
.cp-close { font-size: 36rpx; color: #bbb; }
.cp-no-use { display: flex; justify-content: space-between; align-items: center; padding: 24rpx 30rpx; border-bottom: 1rpx solid #f5f0eb; font-size: 28rpx; color: #666; flex-shrink: 0; }
.cp-check { color: #3d2a1e; font-weight: 700; font-size: 28rpx; }
.cp-list { flex: 1; overflow-y: auto; padding: 16rpx 24rpx; display: flex; flex-direction: column; gap: 16rpx; }
.cp-item { display: flex; align-items: stretch; border-radius: 16rpx; overflow: hidden; box-shadow: 0 2rpx 12rpx rgba(107,79,58,0.08); position: relative; }
.cp-item.cp-selected { box-shadow: 0 0 0 3rpx #3d2a1e; }
.cp-item.cp-disabled { opacity: 0.45; }
.cp-left { width: 180rpx; background: linear-gradient(135deg, #8b6f5e, #6b4f3a); display: flex; flex-direction: column; align-items: center; justify-content: center; padding: 20rpx; gap: 6rpx; flex-shrink: 0; }
.cp-amount { color: #fff; font-size: 52rpx; font-weight: 800; }
.cpu { font-size: 22rpx; font-weight: 400; }
.cp-min { color: rgba(255,255,255,0.75); font-size: 18rpx; }
.cp-right { flex: 1; background: #faf8f5; padding: 20rpx; display: flex; flex-direction: column; justify-content: center; gap: 6rpx; }
.cp-name { font-size: 26rpx; font-weight: 700; color: #2c2c2c; }
.cp-scope { font-size: 22rpx; color: #999; }
.cp-expire { font-size: 20rpx; color: #bbb; }
.cp-check-mark { position: absolute; right: 16rpx; top: 50%; transform: translateY(-50%); width: 40rpx; height: 40rpx; background: #3d2a1e; border-radius: 50%; color: #fff; display: flex; align-items: center; justify-content: center; font-size: 22rpx; font-weight: 700; }
.cp-confirm { margin: 16rpx 24rpx; background: #3d2a1e; color: #fff; text-align: center; border-radius: 48rpx; line-height: 88rpx; font-size: 30rpx; font-weight: 600; flex-shrink: 0; }

/* 支付成功弹窗 */
.pay-success-mask { position: fixed; inset: 0; background: rgba(0,0,0,0.5); z-index: 300; display: flex; align-items: center; justify-content: center; }
.pay-success-card { background: #faf8f5; border-radius: 32rpx; padding: 60rpx 50rpx; width: 600rpx; display: flex; flex-direction: column; align-items: center; gap: 16rpx; }
.success-icon { font-size: 80rpx; }
.success-title { font-size: 36rpx; font-weight: 800; color: #2c2c2c; }
.success-sub { font-size: 24rpx; color: #999; }
.success-order-no { font-size: 22rpx; color: #bbb; background: #f5f0eb; padding: 12rpx 24rpx; border-radius: 8rpx; margin-top: 8rpx; }
.success-btns { display: flex; gap: 20rpx; margin-top: 24rpx; width: 100%; }
.success-btn { flex: 1; text-align: center; padding: 22rpx; border-radius: 48rpx; font-size: 28rpx; font-weight: 600; }
.success-btn.primary { background: #3d2a1e; color: #fff; }
.success-btn.secondary { background: #f0e8de; color: #3d2a1e; }
