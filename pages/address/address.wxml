<view class="address-page">
  <view class="address-list" wx:if="{{addresses.length}}">
    <view class="address-item card {{item.isDefault ? 'default-item' : ''}}" wx:for="{{addresses}}" wx:key="id">
      <view class="addr-main" bindtap="selectAddress" data-id="{{item.id}}">
        <view class="addr-header">
          <text class="addr-name">{{item.name}}</text>
          <text class="addr-phone">{{item.phone}}</text>
          <view class="default-tag" wx:if="{{item.isDefault}}">默认</view>
        </view>
        <text class="addr-detail">{{item.province}}{{item.city}}{{item.district}}{{item.detail}}</text>
      </view>
      <view class="addr-actions">
        <view class="addr-btn" catchtap="setDefault" data-id="{{item.id}}" wx:if="{{!item.isDefault}}">设为默认</view>
        <view class="addr-btn" catchtap="editAddress" data-id="{{item.id}}">编辑</view>
        <view class="addr-btn danger" catchtap="deleteAddress" data-id="{{item.id}}">删除</view>
      </view>
    </view>
  </view>

  <view class="empty-state" wx:else>
    <text class="empty-icon">📍</text>
    <text>还没有收货地址</text>
  </view>

  <!-- 新增地址按钮 -->
  <view class="add-addr-btn" bindtap="showAddForm">
    <text>+ 新增收货地址</text>
  </view>

  <!-- 新增/编辑地址弹窗 -->
  <view class="form-mask" wx:if="{{showForm}}" bindtap="hideForm"></view>
  <view class="addr-form card {{showForm ? 'form-show' : ''}}">
    <view class="form-header">
      <text class="form-title">{{editId ? '编辑地址' : '新增地址'}}</text>
      <text class="form-close" bindtap="hideForm">✕</text>
    </view>

    <view class="form-item">
      <text class="form-label">收货人</text>
      <input class="form-input" placeholder="请输入姓名" value="{{form.name}}" bindinput="onFormInput" data-key="name" />
    </view>
    <view class="form-item">
      <text class="form-label">手机号</text>
      <input class="form-input" placeholder="请输入手机号" type="number" value="{{form.phone}}" bindinput="onFormInput" data-key="phone" />
    </view>
    <view class="form-item" bindtap="chooseRegion">
      <text class="form-label">所在地区</text>
      <text class="form-value {{form.province ? '' : 'placeholder'}}">{{form.province ? form.province + form.city + form.district : '请选择省市区'}}</text>
      <text class="form-arrow">›</text>
    </view>
    <view class="form-item">
      <text class="form-label">详细地址</text>
      <input class="form-input" placeholder="街道、门牌号等" value="{{form.detail}}" bindinput="onFormInput" data-key="detail" />
    </view>
    <view class="form-item">
      <text class="form-label">设为默认</text>
      <switch checked="{{form.isDefault}}" bindchange="onDefaultChange" color="#3d2a1e" />
    </view>

    <view class="form-submit btn-primary" bindtap="submitAddress">保存地址</view>
  </view>
</view>
