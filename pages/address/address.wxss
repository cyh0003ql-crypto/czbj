.address-page { background: #f5f0eb; min-height: 100vh; padding: 24rpx; padding-bottom: 140rpx; }

.address-list { display: flex; flex-direction: column; gap: 20rpx; }

.address-item { overflow: hidden; }
.default-item { border: 1rpx solid #c9a882; }

.addr-main { padding: 24rpx; cursor: pointer; }

.addr-header { display: flex; align-items: center; gap: 16rpx; margin-bottom: 10rpx; }
.addr-name { font-size: 30rpx; font-weight: 700; color: #2c2c2c; }
.addr-phone { font-size: 26rpx; color: #666; }
.default-tag { background: #f0e8de; color: #8b6f5e; font-size: 20rpx; padding: 4rpx 12rpx; border-radius: 6rpx; }
.addr-detail { font-size: 26rpx; color: #666; line-height: 1.6; display: block; }

.addr-actions {
  display: flex;
  justify-content: flex-end;
  gap: 16rpx;
  padding: 12rpx 24rpx;
  border-top: 1rpx solid #f0ebe4;
  background: #fafaf8;
}
.addr-btn { font-size: 24rpx; color: #6b4f3a; padding: 8rpx 16rpx; }
.addr-btn.danger { color: #e8624a; }

.add-addr-btn {
  position: fixed;
  bottom: 40rpx;
  left: 24rpx;
  right: 24rpx;
  background: #3d2a1e;
  color: #fff;
  text-align: center;
  font-size: 30rpx;
  font-weight: 600;
  padding: 26rpx;
  border-radius: 48rpx;
}

.empty-state {
  display: flex; flex-direction: column; align-items: center;
  padding: 120rpx 0; gap: 20rpx; color: #bbb; font-size: 28rpx;
}
.empty-icon { font-size: 100rpx; }

/* 表单弹窗 */
.form-mask {
  position: fixed; inset: 0; background: rgba(0,0,0,0.4); z-index: 100;
}

.addr-form {
  position: fixed;
  bottom: -100%;
  left: 0; right: 0;
  border-radius: 32rpx 32rpx 0 0;
  padding: 0 0 env(safe-area-inset-bottom);
  z-index: 200;
  transition: bottom 0.3s ease;
}

.addr-form.form-show { bottom: 0; }

.form-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx 30rpx 20rpx;
  border-bottom: 1rpx solid #f0ebe4;
}
.form-title { font-size: 32rpx; font-weight: 700; color: #2c2c2c; }
.form-close { font-size: 36rpx; color: #bbb; }

.form-item {
  display: flex;
  align-items: center;
  padding: 24rpx 30rpx;
  border-bottom: 1rpx solid #f5f0eb;
  gap: 20rpx;
}
.form-label { width: 140rpx; font-size: 28rpx; color: #666; flex-shrink: 0; }
.form-input { flex: 1; font-size: 28rpx; color: #2c2c2c; }
.form-value { flex: 1; font-size: 28rpx; color: #2c2c2c; }
.form-value.placeholder { color: #bbb; }
.form-arrow { font-size: 32rpx; color: #bbb; }

.form-submit {
  margin: 24rpx 30rpx;
  text-align: center;
  line-height: 88rpx;
  border-radius: 44rpx;
  font-size: 30rpx;
  font-weight: 600;
  background: #3d2a1e;
  color: #fff;
}
