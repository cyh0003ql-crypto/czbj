<view class="category-page">
  <!-- 搜索栏 -->
  <view class="search-wrap">
    <view class="search-bar" bindtap="onSearch">
      <text class="search-icon">🔍</text>
      <input class="search-input" placeholder="搜索商品或服务" placeholder-style="color:#bbb;" bindinput="onSearchInput" value="{{searchKeyword}}" />
    </view>
    <view class="notify-btn">🔔</view>
  </view>

  <view class="category-body">
    <!-- 左侧分类菜单 -->
    <scroll-view class="cat-menu" scroll-y="{{true}}">
      <view class="cat-menu-item {{item.id === currentCat ? 'active' : ''}}"
        wx:for="{{categories}}" wx:key="id"
        bindtap="onCatTap" data-id="{{item.id}}">
        <text>{{item.name}}</text>
      </view>
    </scroll-view>

    <!-- 右侧内容 -->
    <scroll-view class="cat-content" scroll-y="{{true}}" bindscrolltolower="onLoadMore">
      <!-- 定制服务卡片（全部分类显示） -->
      <block wx:if="{{currentCat === 'all'}}">
        <view class="service-cards">
          <view class="service-card card" wx:for="{{serviceCards}}" wx:key="id" bindtap="goCustomize">
            <view class="service-info">
              <text class="service-name">{{item.name}}</text>
              <text class="service-desc">{{item.desc}}</text>
              <view class="service-btn">
                <text>立即定制 ›</text>
              </view>
            </view>
            <image class="service-img" src="{{item.img}}" mode="aspectFill"></image>
          </view>
        </view>
      </block>

      <!-- 精选商品标题 -->
      <view class="section-header">
        <text class="section-title">精选商品</text>
        <text class="section-more">更多 ›</text>
      </view>

      <!-- 商品列表 -->
      <view class="product-list">
        <view class="product-list-item card" wx:for="{{products}}" wx:key="id" bindtap="goProductDetail" data-id="{{item.id}}">
          <image class="list-img" src="{{item.image}}" mode="aspectFill" lazy-load="{{true}}"></image>
          <view class="list-info">
            <text class="list-name">{{item.name}}</text>
            <view class="list-tags">
              <text class="tag" wx:for="{{item.tags}}" wx:key="*this" wx:for-item="tag">{{tag}}</text>
            </view>
            <view class="list-bottom">
              <view class="list-price">
                <text class="price-unit">¥</text>
                <text class="price-num-sm">{{item.price}}</text>
                <text class="price-suffix"> 起</text>
              </view>
              <view class="list-cart-btn" catchtap="addToCart" data-id="{{item.id}}">🛒</view>
            </view>
          </view>
          <view class="list-wishlist" catchtap="onWishlist" data-id="{{item.id}}">
            <text class="{{item.wished ? 'wished' : ''}}">♡</text>
          </view>
        </view>
      </view>

      <!-- 加载更多 -->
      <view class="load-more">
        <text wx:if="{{loading}}">加载中...</text>
        <text wx:elif="{{noMore}}">— 已显示全部 —</text>
        <text wx:else>上滑加载更多</text>
      </view>
    </scroll-view>
  </view>
</view>
